{
  "manifest_version": 3,
  "name": "Cross-Origin Storage Polyfill",
  "version": "1.1",
  "description": "A polyfill for the Cross-Origin Storage API, packaged as a Chrome extension.",
  "permissions": ["storage", "unlimitedStorage"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "logo-cos.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["main-world.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "512": "logo-cos.png"
  }
}
